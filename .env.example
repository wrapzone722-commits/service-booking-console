# Копируйте в .env и заполните при необходимости.

# Версия в URL admin styles.css / app.js (сброс кэша). По умолчанию — поле version из package.json.
# ASSET_VERSION=1.0.2

# База данных (по умолчанию: data/service_booking.db)
# DB_PATH=/data/service_booking.db

# Push-уведомления (APNs). Без них консоль работает, но push не отправляются.
# Ключ .p8 создаётся в Apple Developer → Keys → Apple Push Notifications service.
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.servicebooking.app
# Путь к файлу .p8 или содержимое ключа:
# APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
# APNS_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Для продакшена (App Store):
# APNS_PRODUCTION=1

# Дополнительные хосты для сжатых превью /api/v1/image/preview (через запятую), если картинки на CDN.
# IMAGE_PREVIEW_HOSTS=cdn.example.com,static.example.com
